# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# رابط الموقع (يُضاف تلقائياً في Netlify)
SITE_URL=https://your-site.netlify.app
